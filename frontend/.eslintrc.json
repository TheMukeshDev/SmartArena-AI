{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "script"
    },
    "globals": {
        "Chart": "readonly",
        "gsap": "readonly",
        "firebase": "readonly",
        "CONFIG": "readonly",
        "Auth": "writable",
        "Admin": "writable",
        "I18N": "writable",
        "initFirebase": "writable",
        "showToast": "writable",
        "getAuth": "writable",
        "getDb": "writable",
        "google": "readonly",
        "StadiumMap": "readonly",
        "__GOOGLE_MAPS_API_KEY__": "readonly"
    },
    "rules": {
        "no-redeclare": "off",
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_|^Admin$|^Auth$|^initFirebase$|^getDb$|^getAuth$|^StadiumMap$" }],
        "no-console": "off",
        "eqeqeq": ["error", "always"],
        "no-eval": "error",
        "no-implied-eval": "error",
        "no-new-func": "error"
    }
}
