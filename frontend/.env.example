# =============================================================================
# SmartArena AI — Frontend Environment Variables (Vite)
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Google Maps JavaScript API Key (Frontend)
# ------------------------------------------------------------------
# This key IS expected to be visible in the browser bundle — that is
# normal for the Maps JS SDK. Security is enforced via RESTRICTIONS
# set in Google Cloud Console, NOT by keeping the key secret.
#
# Required restrictions:
#   - Application restriction: HTTP referrer
#   - Allowed referrers: your exact deployed origin(s), e.g.
#       https://smart-arena-ai.vercel.app/*
#       http://localhost:5173/*    (local dev)
#       http://localhost:3000/*    (Vite default)
#   - API restriction: Maps JavaScript API only
# ------------------------------------------------------------------
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-frontend-api-key
