# =============================================================================
# SmartArena AI — Git Ignore Rules
# =============================================================================

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Virtual Environment ────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Node ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment Variables ───────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
firebase-credentials.json
*-service-account.json

# ── IDE ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ──────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Firebase ────────────────────────────────────────────────────────────
.firebase/
.firebaserc.bak

# ── Logs ────────────────────────────────────────────────────────────────
*.log
logs/
