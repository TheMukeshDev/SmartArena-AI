rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default: Deny all access ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Users Collection ────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == resource.data.role);
    }

    // ── Incidents Collection ────────────────────────────────────────
    match /incidents/{incidentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.token.role in ['admin', 'volunteer'];
      allow update: if request.auth != null
                    && request.auth.token.role == 'admin';
      allow delete: if request.auth != null
                    && request.auth.token.role == 'admin';
    }

    // ── Crowd Data Collection ───────────────────────────────────────
    match /crowd_data/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin';
    }

    // ── Volunteer Collection ────────────────────────────────────────
    match /volunteers/{volunteerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == volunteerId
                       || request.auth.token.role == 'admin');
    }

    // ── Sustainability Data ─────────────────────────────────────────
    match /sustainability/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.role == 'admin';
    }

    // ── AI Predictions ──────────────────────────────────────────────
    match /predictions/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Server-side only
    }
  }
}
