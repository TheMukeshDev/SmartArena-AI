# =============================================================================
# SmartArena AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production

# Server
HOST=0.0.0.0
PORT=5000

# Firebase (Backend — Admin SDK)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase (Client-side config — used by frontend)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Weather API Key (Backend Only — NEVER exposed to frontend)
# ------------------------------------------------------------------
# Only needed if you switch from the default keyless Open-Meteo API
# to a key-based weather provider (e.g. OpenWeatherMap, WeatherAPI).
# This key must ONLY be read server-side in weather.py.
#
# Required restrictions (if using Google Weather API):
#   - Application restriction: IP address (your backend server IP)
#   - API restriction: Weather API only
# ------------------------------------------------------------------
# WEATHER_API_KEY=your-weather-api-key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Rate Limiting (SQLite-backed)
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_DB_PATH=ratelimit.db

# Caching (SQLite-backed)
CACHE_DB_PATH=cache.db
CACHE_TTL_SECONDS=3600

# Security
FORCE_HTTPS=0
